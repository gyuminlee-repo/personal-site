---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Footer from '../components/sections/Footer.astro';
import Software from '../components/sections/Software.astro';
---
<Base title="Gyumin Lee" description="Methanotroph engineer · synthetic biology postdoc">
  <Nav lang="en" currentPath="/" />
  <main>
    <Hero lang="en" />
    {/* Phase 2.2 mounts AboutSection here */}
    <section id="about" class="scroll-mt-24" />
    <Software lang="en" />
    {/* Phase 3.x mounts Publications here */}
    <section id="publications" class="scroll-mt-24" />
    {/* Contact placeholder */}
    <section id="contact" class="scroll-mt-24" />
  </main>
  <Footer lang="en" />
</Base>
