---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import PresentationsList from '../components/sections/PresentationsList.astro';
---
<Base
  title="Presentations — Gyu Min Lee"
  description="Recent talks at lab seminars and external venues."
  lang="en"
  path="/presentations"
>
  <Nav lang="en" currentPath="/presentations" />
  <main class="pt-24 pb-32">
    <div class="mx-auto max-w-6xl px-6 md:px-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground">Presentations</h1>
      <p class="mt-3 max-w-2xl text-base text-muted-foreground">
        Recent talks, seminars, and lab presentations.
      </p>
    </div>
    <div class="mt-12 px-6 md:px-8">
      <PresentationsList lang="en" />
    </div>
  </main>
  <Footer lang="en" />
</Base>
