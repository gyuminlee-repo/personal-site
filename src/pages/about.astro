---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import About from '../components/sections/About.astro';
---
<Base
  title="About — Gyumin Lee"
  description="Postdoc at KRIBB C1 Team. Methanotroph and methylotroph engineering, ALE, agentic tooling."
  lang="en"
  path="/about"
>
  <Nav lang="en" currentPath="/about" />
  <main class="pt-24 pb-32">
    <div class="mx-auto max-w-6xl px-6 md:px-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground">About</h1>
    </div>
    <About lang="en" />
  </main>
  <Footer lang="en" />
</Base>
