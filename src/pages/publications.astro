---
import Base from '../layouts/Base.astro';
import Nav from '../components/sections/Nav.astro';
import Footer from '../components/sections/Footer.astro';
import Publications from '../components/sections/Publications.astro';
---
<Base
  title="Publications — Gyumin Lee"
  description="Peer-reviewed and conference publications, synced daily from Google Scholar."
  lang="en"
  path="/publications"
>
  <Nav lang="en" currentPath="/publications" />
  <main class="pt-24 pb-32">
    <div class="mx-auto max-w-6xl px-6 md:px-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground">Publications</h1>
    </div>
    <Publications lang="en" />
  </main>
  <Footer lang="en" />
</Base>
