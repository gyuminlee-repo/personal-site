---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/sections/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import CvFull from '../../components/sections/CvFull.astro';
import CvDownloadButton from '../../components/CvDownloadButton.astro';
---
<Base
  title="이력서 — 이규민"
  description="학력·경력·기술·주요 논문."
  lang="ko"
  path="/ko/cv"
>
  <Nav lang="ko" currentPath="/ko/cv" />
  <main class="pt-24 pb-32">
    <div class="mx-auto max-w-6xl px-6 md:px-8">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground">이력서</h1>
        <CvDownloadButton lang="ko" />
      </div>
    </div>
    <div class="mt-12 px-6 md:px-8">
      <CvFull lang="ko" />
    </div>
  </main>
  <Footer lang="ko" />
</Base>
