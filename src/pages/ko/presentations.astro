---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/sections/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import PresentationsList from '../../components/sections/PresentationsList.astro';
---
<Base
  title="발표 — 이규민"
  description="최근 발표·세미나 기록."
  lang="ko"
  path="/ko/presentations"
>
  <Nav lang="ko" currentPath="/ko/presentations" />
  <main class="pt-24 pb-32">
    <div class="mx-auto max-w-6xl px-6 md:px-8">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-foreground">발표</h1>
      <p class="mt-3 max-w-2xl text-base text-muted-foreground">최근 학술·연구실 발표 기록.</p>
    </div>
    <div class="mt-12 px-6 md:px-8">
      <PresentationsList lang="ko" />
    </div>
  </main>
  <Footer lang="ko" />
</Base>
