---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/sections/Nav.astro';
import Hero from '../../components/sections/Hero.astro';
import Footer from '../../components/sections/Footer.astro';
import Software from '../../components/sections/Software.astro';
---
<Base title="이규민" description="메탄자화균 엔지니어 · 합성생물학 박사후연구원" lang="ko">
  <Nav lang="ko" currentPath="/ko/" />
  <main>
    <Hero lang="ko" />
    {/* Phase 2.2 mounts AboutSection here */}
    <section id="about" class="scroll-mt-24" />
    <Software lang="ko" />
    {/* Phase 3.x mounts Publications here */}
    <section id="publications" class="scroll-mt-24" />
    {/* Contact placeholder */}
    <section id="contact" class="scroll-mt-24" />
  </main>
  <Footer lang="ko" />
</Base>
