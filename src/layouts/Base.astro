---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';
import CmdK from '../islands/CmdK';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'ko';
  path?: string;
  noindex?: boolean;
}
const { title, description = '', lang = 'en', path = '/', noindex = false } = Astro.props;

const SITE = 'https://gyuminlee.dev';

// Compute EN/KO mirror paths for hreflang alternates
const stripKo = (p: string) => (p.startsWith('/ko/') ? p.slice(3) || '/' : p);
const addKo = (p: string) => (p === '/' ? '/ko/' : `/ko${p}`);
const enPath = lang === 'en' ? path : stripKo(path);
const koPath = lang === 'ko' ? path : addKo(path);
const canonicalUrl = `${SITE}${path}`;
const enUrl = `${SITE}${enPath}`;
const koUrl = `${SITE}${koPath}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    {lang === 'ko' && (
      <>
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        <link
          rel="stylesheet"
          href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
        />
      </>
    )}
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <CmdK client:idle lang={lang} />
  </body>
</html>
