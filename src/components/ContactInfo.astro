---
import bioEn from '../data/bio.en.json';

export interface Props {
  lang: 'en' | 'ko';
}
const { lang } = Astro.props;

const email = bioEn.meta.contact.email;
const githubUser = bioEn.meta.contact.github;
const scholarId = bioEn.meta.contact.scholar;

const items = [
  {
    key: 'email',
    label: lang === 'ko' ? '이메일' : 'Email',
    value: email,
    href: `mailto:${email}`,
    icon: 'mail',
  },
  {
    key: 'github',
    label: lang === 'ko' ? '깃허브' : 'GitHub',
    value: `@${githubUser}`,
    href: `https://github.com/${githubUser}`,
    icon: 'github',
  },
  {
    key: 'scholar',
    label: lang === 'ko' ? '구글 스칼라' : 'Google Scholar',
    value: lang === 'ko' ? '프로필 보기' : 'View profile',
    href: `https://scholar.google.com/citations?user=${scholarId}`,
    icon: 'scholar',
  },
  {
    key: 'linkedin',
    label: 'LinkedIn',
    value: lang === 'ko' ? '준비 중' : 'Coming soon',
    href: null,
    icon: 'linkedin',
  },
  {
    key: 'kribb',
    label: lang === 'ko' ? '소속·주소' : 'Affiliation',
    value: lang === 'ko'
      ? '한국생명공학연구원 (KRIBB) 합성생물학연구센터 · 대전 유성구 과학로 125'
      : 'KRIBB, Center for Synthetic Biology · 125 Gwahak-ro, Yuseong-gu, Daejeon, South Korea',
    href: 'https://www.kribb.re.kr',
    icon: 'pin',
  },
];
---
<section class="mx-auto max-w-3xl">
  <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {items.map((item) => (
      <li class="rounded-lg border border-border bg-card p-5">
        <div class="flex items-start gap-3">
          <div class="mt-0.5 text-muted-foreground">
            {item.icon === 'mail' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            )}
            {item.icon === 'github' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            )}
            {item.icon === 'scholar' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
            )}
            {item.icon === 'linkedin' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            )}
            {item.icon === 'pin' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            )}
          </div>
          <div class="min-w-0 flex-1">
            <div class="text-xs font-medium uppercase tracking-[0.14em] text-primary">{item.label}</div>
            <div class="mt-1 break-words text-sm text-foreground">
              {item.href ? (
                <a href={item.href} class="hover:text-primary hover:underline underline-offset-4" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                  {item.value}
                </a>
              ) : (
                <span class="text-muted-foreground">{item.value}</span>
              )}
            </div>
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>
