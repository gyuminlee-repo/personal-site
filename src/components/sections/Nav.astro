---
interface Props { lang?: 'en' | 'ko'; currentPath?: string; }
const { lang = 'en', currentPath = '/' } = Astro.props;

const enPrefix = '';
const koPrefix = '/ko';
const prefix = lang === 'ko' ? koPrefix : enPrefix;

const copy = {
  en: {
    brand: 'Gyumin Lee',
    links: [
      { href: `${enPrefix}/`, label: 'Home', match: '/' },
      { href: `${enPrefix}/about`, label: 'About', match: '/about' },
      { href: `${enPrefix}/tools`, label: 'Tools', match: '/tools' },
      { href: `${enPrefix}/publications`, label: 'Publications', match: '/publications' },
      { href: `${enPrefix}/presentations`, label: 'Presentations', match: '/presentations' },
      { href: `${enPrefix}/posts`, label: 'Posts', match: '/posts' },
      { href: `${enPrefix}/cv`, label: 'CV', match: '/cv' },
      { href: `${enPrefix}/contact`, label: 'Contact', match: '/contact' }
    ],
    menuLabel: 'Menu'
  },
  ko: {
    brand: '이규민',
    links: [
      { href: `${koPrefix}/`, label: '홈', match: '/ko/' },
      { href: `${koPrefix}/about`, label: '소개', match: '/ko/about' },
      { href: `${koPrefix}/tools`, label: '도구', match: '/ko/tools' },
      { href: `${koPrefix}/publications`, label: '논문', match: '/ko/publications' },
      { href: `${koPrefix}/presentations`, label: '발표', match: '/ko/presentations' },
      { href: `${koPrefix}/posts`, label: '포스트', match: '/ko/posts' },
      { href: `${koPrefix}/cv`, label: '이력서', match: '/ko/cv' },
      { href: `${koPrefix}/contact`, label: '연락처', match: '/ko/contact' }
    ],
    menuLabel: '메뉴'
  }
} as const;

const t = copy[lang];
const enHome = '/';
const koHome = '/ko/';
const isEnActive = lang === 'en';

// Normalize currentPath for active-link detection
const normalizedPath = currentPath.endsWith('/') && currentPath.length > 1
  ? currentPath.slice(0, -1)
  : currentPath;

const isActive = (match: string) => {
  if (match === '/' || match === '/ko/') {
    return currentPath === match;
  }
  return normalizedPath === match || normalizedPath.startsWith(match + '/');
};

// EN/KO toggle target: prefer mirror of current path
const stripKo = (p: string) => (p.startsWith('/ko/') ? p.slice(3) || '/' : p);
const addKo = (p: string) => (p === '/' ? '/ko/' : `/ko${p}`);
const enHref = isEnActive ? currentPath : stripKo(currentPath);
const koHref = !isEnActive ? currentPath : addKo(currentPath);
void prefix;
---
<nav
  id="site-nav"
  class="sticky top-0 z-sticky w-full backdrop-blur-md bg-background/80 border-b border-border"
>
  <div class="mx-auto max-w-grid w-full px-6 md:px-12 h-16 flex items-center justify-between gap-4">
    <a
      href={isEnActive ? enHome : koHome}
      class="font-sans font-semibold text-foreground tracking-tight text-base md:text-lg hover:text-primary transition"
    >{t.brand}</a>

    <div class="hidden md:flex items-center gap-6 lg:gap-7">
      {t.links.map((l) => (
        <a
          href={l.href}
          class={`text-sm transition ${isActive(l.match) ? 'text-foreground font-medium' : 'text-muted-foreground hover:text-foreground'}`}
          aria-current={isActive(l.match) ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <kbd class="hidden lg:inline-flex items-center px-2 py-1 rounded border border-border bg-secondary text-xs font-mono text-muted-foreground">⌘K</kbd>
      <div class="text-xs font-mono">
        <a
          href={enHref}
          class={`hover:text-foreground transition ${isEnActive ? 'text-foreground font-medium' : 'text-muted-foreground'}`}
          aria-current={isEnActive ? 'page' : undefined}
        >EN</a>
        <span class="text-muted-foreground mx-1">/</span>
        <a
          href={koHref}
          class={`hover:text-foreground transition ${!isEnActive ? 'text-foreground font-medium' : 'text-muted-foreground'}`}
          aria-current={!isEnActive ? 'page' : undefined}
        >KO</a>
      </div>

      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer p-2 text-foreground"
          aria-label={t.menuLabel}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </summary>
        <div class="absolute right-0 mt-2 w-48 rounded-md border border-border bg-card shadow-md p-2 flex flex-col">
          {t.links.map((l) => (
            <a
              href={l.href}
              class={`px-3 py-2 text-sm rounded transition ${isActive(l.match) ? 'bg-secondary text-foreground font-medium' : 'text-foreground hover:bg-secondary'}`}
              aria-current={isActive(l.match) ? 'page' : undefined}
            >{l.label}</a>
          ))}
        </div>
      </details>
    </div>
  </div>
</nav>
