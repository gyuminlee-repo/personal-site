---
import bioEn from '../../data/bio.en.json';
import bioKo from '../../data/bio.ko.json';

interface Props { lang?: 'en' | 'ko'; }
const { lang = 'en' } = Astro.props;
const bio = lang === 'ko' ? bioKo : bioEn;

// KO scaffold may contain empty strings as Phase 3.2 placeholders.
// Render the EN values as graceful fallback so the page never shows blank slots
// even if a KO key has not been translated yet.
const fallback = bioEn;
const t = <T,>(koValue: T, enValue: T): T => {
  if (typeof koValue === 'string' && koValue.trim() === '') return enValue;
  return koValue;
};

const about = {
  eyebrow: t(bio.about.eyebrow, fallback.about.eyebrow),
  heading: t(bio.about.heading, fallback.about.heading),
  lede: t(bio.about.lede, fallback.about.lede),
  paragraphs: bio.about.paragraphs.map((p, i) => t(p, fallback.about.paragraphs[i] ?? '')),
};

const education = {
  heading: t(bio.education.heading, fallback.education.heading),
  items: bio.education.items.map((item, i) => {
    const fb = fallback.education.items[i] ?? item;
    return {
      degree: t(item.degree, fb.degree),
      institution: t(item.institution, fb.institution),
      lab: item.lab == null ? null : t(item.lab, fb.lab ?? ''),
      period: t(item.period, fb.period),
      highlight: item.highlight == null ? null : t(item.highlight, fb.highlight ?? ''),
    };
  }),
};

const experience = {
  heading: t(bio.experience.heading, fallback.experience.heading),
  items: bio.experience.items.map((item, i) => {
    const fb = fallback.experience.items[i] ?? item;
    return {
      role: t(item.role, fb.role),
      org: t(item.org, fb.org),
      lab: t(item.lab, fb.lab),
      period: t(item.period, fb.period),
      highlight: t(item.highlight, fb.highlight),
    };
  }),
};

const skills = {
  heading: t(bio.skills.heading, fallback.skills.heading),
  columns: bio.skills.columns.map((col, i) => {
    const fb = fallback.skills.columns[i] ?? col;
    return {
      label: t(col.label, fb.label),
      items: col.items.map((it, j) => t(it, fb.items[j] ?? '')),
    };
  }),
};
---
<section
  id="about"
  class="border-t border-border py-24 md:py-32"
  data-animate="fade-up"
>
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <p class="mb-4 text-xs font-medium uppercase tracking-[0.18em] text-primary">
      {about.eyebrow}
    </p>
    <h2 class="max-w-3xl text-4xl font-semibold tracking-tight text-foreground md:text-5xl">
      {about.heading}
    </h2>

    <div class="mt-12 grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-x-12">
      <div class="md:col-span-7">
        <p class="text-lg leading-relaxed text-foreground md:text-xl">
          {about.lede}
        </p>
        <div class="mt-6 space-y-4 text-base leading-relaxed text-muted-foreground md:text-lg">
          {about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <aside class="md:col-span-5 md:pl-4">
        <div class="rounded-lg border border-border bg-card p-6 md:p-7">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
            {education.heading}
          </h3>
          <ul class="mt-4 space-y-5">
            {education.items.map((item) => (
              <li class="text-sm">
                <div class="font-medium text-foreground">{item.degree}</div>
                <div class="mt-0.5 text-muted-foreground">{item.institution}</div>
                {item.lab && <div class="mt-0.5 text-xs text-muted-foreground">{item.lab}</div>}
                <div class="mt-1 font-mono text-xs text-muted-foreground">{item.period}</div>
                {item.highlight && (
                  <div class="mt-2 text-xs leading-relaxed text-muted-foreground">{item.highlight}</div>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="mt-6 rounded-lg border border-border bg-card p-6 md:p-7">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
            {experience.heading}
          </h3>
          <ul class="mt-4 space-y-5">
            {experience.items.map((item) => (
              <li class="text-sm">
                <div class="font-medium text-foreground">{item.role}</div>
                <div class="mt-0.5 text-muted-foreground">{item.org}</div>
                {item.lab && <div class="mt-0.5 text-xs text-muted-foreground">{item.lab}</div>}
                <div class="mt-1 font-mono text-xs text-muted-foreground">{item.period}</div>
                {item.highlight && (
                  <div class="mt-2 text-xs leading-relaxed text-muted-foreground">{item.highlight}</div>
                )}
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>

    <div class="mt-16">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
        {skills.heading}
      </h3>
      <div class="mt-6 grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-10">
        {skills.columns.map((col) => (
          <div>
            <div class="mb-3 text-xs font-medium uppercase tracking-[0.14em] text-primary">
              {col.label}
            </div>
            <ul class="space-y-2 text-sm text-muted-foreground">
              {col.items.filter((it) => it && it.trim() !== '').map((it) => (
                <li class="leading-snug">{it}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
