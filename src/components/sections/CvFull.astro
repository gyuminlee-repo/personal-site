---
import bioEn from '../../data/bio.en.json';
import bioKo from '../../data/bio.ko.json';
import pubData from '../../data/publications.json';

export interface Props {
  lang: 'en' | 'ko';
}
const { lang } = Astro.props;

const fallback = bioEn;
const bio = lang === 'ko' ? bioKo : bioEn;

const t = <T,>(koValue: T, enValue: T): T => {
  if (typeof koValue === 'string' && koValue.trim() === '') return enValue;
  return koValue;
};

const meta = {
  name: t(bio.meta.name, fallback.meta.name),
  korean_name: t(bio.meta.korean_name, fallback.meta.korean_name),
  title: t(bio.meta.title, fallback.meta.title),
  affiliation: t(bio.meta.affiliation, fallback.meta.affiliation),
  pi: t(bio.meta.pi, fallback.meta.pi),
  location: t(bio.meta.location, fallback.meta.location),
  contact: bio.meta.contact,
};

const education = {
  heading: t(bio.education.heading, fallback.education.heading),
  items: bio.education.items.map((item, i) => {
    const fb = fallback.education.items[i] ?? item;
    return {
      degree: t(item.degree, fb.degree),
      institution: t(item.institution, fb.institution),
      lab: item.lab == null ? null : t(item.lab, fb.lab ?? ''),
      period: t(item.period, fb.period),
      highlight: item.highlight == null ? null : t(item.highlight, fb.highlight ?? ''),
    };
  }),
};

const experience = {
  heading: t(bio.experience.heading, fallback.experience.heading),
  items: bio.experience.items.map((item, i) => {
    const fb = fallback.experience.items[i] ?? item;
    return {
      role: t(item.role, fb.role),
      org: t(item.org, fb.org),
      lab: t(item.lab, fb.lab),
      period: t(item.period, fb.period),
      highlight: t(item.highlight, fb.highlight),
    };
  }),
};

const skills = {
  heading: t(bio.skills.heading, fallback.skills.heading),
  columns: bio.skills.columns.map((col, i) => {
    const fb = fallback.skills.columns[i] ?? col;
    return {
      label: t(col.label, fb.label),
      items: col.items.map((it, j) => t(it, fb.items[j] ?? '')),
    };
  }),
};

const pubsRanked = [...pubData.publications].sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
const pubFirst = pubsRanked.slice(0, 8);

const labels = {
  bio: lang === 'ko' ? '소개' : 'Biography',
  contact: lang === 'ko' ? '연락처' : 'Contact',
  email: lang === 'ko' ? '이메일' : 'Email',
  github: lang === 'ko' ? '깃허브' : 'GitHub',
  scholar: lang === 'ko' ? '구글 스칼라' : 'Google Scholar',
  publications: lang === 'ko' ? '주요 논문' : 'Selected Publications',
  publicationsAll: lang === 'ko' ? '전체 논문 목록 보기 →' : 'See full publication list →',
  awards: lang === 'ko' ? '수상·학회' : 'Awards & Service',
  awardPlaceholder: lang === 'ko'
    ? '한국생물공학회 학술대회 다년 발표 (2018–2025).'
    : 'Repeated invited and contributed talks at KSBB annual meetings (2018–2025).',
  affiliationLabel: lang === 'ko' ? '소속' : 'Affiliation',
  piLabel: lang === 'ko' ? 'PI' : 'Principal Investigator',
  locationLabel: lang === 'ko' ? '위치' : 'Location',
};
---
<article class="cv-full mx-auto max-w-4xl">
  <header class="border-b border-border pb-6">
    <h2 class="text-3xl font-semibold tracking-tight text-foreground">
      {meta.name}{lang === 'ko' && meta.korean_name !== meta.name ? null : ''}
      {lang === 'en' && (
        <span class="ml-2 text-base font-normal text-muted-foreground">({meta.korean_name})</span>
      )}
    </h2>
    <p class="mt-2 text-base text-muted-foreground">{meta.title}</p>
    <dl class="mt-4 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <div>
        <dt class="inline font-medium text-foreground">{labels.affiliationLabel}: </dt>
        <dd class="inline text-muted-foreground">{meta.affiliation}</dd>
      </div>
      <div>
        <dt class="inline font-medium text-foreground">{labels.piLabel}: </dt>
        <dd class="inline text-muted-foreground">{meta.pi}</dd>
      </div>
      <div>
        <dt class="inline font-medium text-foreground">{labels.locationLabel}: </dt>
        <dd class="inline text-muted-foreground">{meta.location}</dd>
      </div>
      <div>
        <dt class="inline font-medium text-foreground">{labels.email}: </dt>
        <dd class="inline">
          <a class="text-muted-foreground hover:text-primary hover:underline underline-offset-4" href={`mailto:${meta.contact.email}`}>{meta.contact.email}</a>
        </dd>
      </div>
    </dl>
  </header>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{labels.bio}</h3>
    <div class="mt-3 space-y-3 text-sm leading-relaxed text-muted-foreground">
      {bio.about.paragraphs.map((p, i) => <p>{t(p, fallback.about.paragraphs[i] ?? '')}</p>)}
    </div>
  </section>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{education.heading}</h3>
    <ul class="mt-4 space-y-5">
      {education.items.map((item) => (
        <li class="grid grid-cols-1 gap-1 text-sm md:grid-cols-12 md:gap-4">
          <div class="md:col-span-3">
            <span class="font-mono text-xs text-muted-foreground">{item.period}</span>
          </div>
          <div class="md:col-span-9">
            <div class="font-medium text-foreground">{item.degree}</div>
            <div class="mt-0.5 text-muted-foreground">{item.institution}</div>
            {item.lab && <div class="mt-0.5 text-xs text-muted-foreground">{item.lab}</div>}
            {item.highlight && (
              <div class="mt-2 text-xs leading-relaxed text-muted-foreground">{item.highlight}</div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{experience.heading}</h3>
    <ul class="mt-4 space-y-5">
      {experience.items.map((item) => (
        <li class="grid grid-cols-1 gap-1 text-sm md:grid-cols-12 md:gap-4">
          <div class="md:col-span-3">
            <span class="font-mono text-xs text-muted-foreground">{item.period}</span>
          </div>
          <div class="md:col-span-9">
            <div class="font-medium text-foreground">{item.role}</div>
            <div class="mt-0.5 text-muted-foreground">{item.org}</div>
            {item.lab && <div class="mt-0.5 text-xs text-muted-foreground">{item.lab}</div>}
            {item.highlight && (
              <div class="mt-2 text-xs leading-relaxed text-muted-foreground">{item.highlight}</div>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{skills.heading}</h3>
    <div class="mt-4 grid grid-cols-1 gap-6 md:grid-cols-3">
      {skills.columns.map((col) => (
        <div>
          <div class="mb-2 text-xs font-medium uppercase tracking-[0.14em] text-primary">{col.label}</div>
          <ul class="space-y-1.5 text-sm text-muted-foreground">
            {col.items.filter((it) => it && it.trim() !== '').map((it) => (
              <li class="leading-snug">{it}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{labels.publications}</h3>
    <ol class="mt-4 list-decimal space-y-3 pl-5 text-sm text-muted-foreground">
      {pubFirst.map((pub) => (
        <li>
          <span class="text-foreground">{pub.title}</span>
          {pub.authors && pub.authors.length > 0 && (
            <span> — {pub.authors.slice(0, 4).join(', ')}{pub.authors.length > 4 ? ' et al.' : ''}</span>
          )}
          <span> ({pub.year}{pub.journal ? `, ${pub.journal}` : ''}).</span>
          {pub.url && (
            <> <a class="hover:text-primary hover:underline underline-offset-4" href={pub.url} target="_blank" rel="noopener noreferrer">link</a>.</>
          )}
        </li>
      ))}
    </ol>
    <p class="mt-4 text-sm">
      <a class="text-primary hover:underline underline-offset-4" href={lang === 'ko' ? '/ko/publications' : '/publications'}>
        {labels.publicationsAll}
      </a>
    </p>
  </section>

  <section class="mt-10">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">{labels.awards}</h3>
    <p class="mt-3 text-sm text-muted-foreground">{labels.awardPlaceholder}</p>
  </section>
</article>

<style>
  @media print {
    nav, footer { display: none !important; }
    .cv-full { max-width: none; }
    .cv-full a { color: inherit; text-decoration: none; }
    .cv-full a[href^="http"]::after { content: " (" attr(href) ")"; font-size: 0.75em; color: #555; }
  }
</style>
