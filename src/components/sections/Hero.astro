---
import Typewriter from '../../islands/Typewriter';
interface Props { lang?: 'en' | 'ko'; }
const { lang = 'en' } = Astro.props;

const copy = {
  en: {
    eyebrow: 'KRIBB · C1 Team · Postdoc',
    name: 'Gyumin Lee',
    role: 'Methanotroph Engineer',
    leadBefore: 'I build ',
    leadAfter: '.',
    bio: 'Engineering microbes that turn methane into useful molecules, increasingly with the help of agentic coding tools.',
    cta: { projects: 'View Projects', publications: 'Read Publications', email: 'Email me' },
    scroll: 'scroll'
  },
  ko: {
    eyebrow: 'KRIBB · C1팀 · 박사후연구원',
    name: '이규민',
    role: '메탄자화균 엔지니어',
    leadBefore: '',
    leadAfter: '를 만든다.',
    bio: '메탄을 유용한 물질로 전환하는 미생물을 만든다. 에이전틱 코딩 도구를 적극 활용한다.',
    cta: { projects: '프로젝트 보기', publications: '논문 보기', email: '이메일' },
    scroll: '아래로'
  }
} as const;

const t = copy[lang];
---
<section
  id="hero"
  class="relative w-full min-h-[88vh] flex items-center bg-background"
>
  <div class="mx-auto max-w-grid w-full px-6 md:px-12 py-24 md:py-32">
    <p class="text-sm font-mono uppercase tracking-wider text-muted-foreground mb-6">
      {t.eyebrow}
    </p>

    <h1 class="font-sans font-bold tracking-tight text-foreground text-5xl md:text-6xl lg:text-7xl mb-6">
      {t.name}
    </h1>

    <p class="text-2xl md:text-3xl text-foreground mb-6 max-w-3xl">
      {t.leadBefore}
      <span
        id="typewriter-slot"
        class="inline-block min-w-[16ch] align-baseline"
        data-lang={lang}
      ><Typewriter client:idle lang={lang} /></span>{t.leadAfter}
    </p>

    <p class="text-base md:text-lg text-muted-foreground max-w-2xl mb-10 leading-relaxed">
      {t.bio}
    </p>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
      <a
        href="#software"
        class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary text-primary-foreground font-medium shadow-sm hover:shadow-md transition focus:outline-none focus:shadow-focus"
      >{t.cta.projects}</a>
      <a
        href="#publications"
        class="inline-flex items-center justify-center px-6 py-3 rounded-md border border-border bg-background text-foreground font-medium hover:bg-secondary transition focus:outline-none focus:shadow-focus"
      >{t.cta.publications}</a>
      <a
        href="mailto:rbals1012@gmail.com"
        class="inline-flex items-center justify-center px-6 py-3 rounded-md text-foreground font-medium hover:bg-secondary transition focus:outline-none focus:shadow-focus"
      >{t.cta.email}</a>
    </div>
  </div>

  <a
    href="#about"
    aria-label={t.scroll}
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-muted-foreground hover:text-foreground transition text-sm font-mono inline-flex items-center gap-2"
  >
    <span>↓</span>
    <span>{t.scroll}</span>
  </a>
</section>
