---
import Typewriter from '../../islands/Typewriter';
interface Props { lang?: 'en' | 'ko'; }
const { lang = 'en' } = Astro.props;

const copy = {
  en: {
    eyebrow: 'KRIBB · C1 Team · Postdoc',
    name: 'Gyumin Lee',
    leadBefore: 'I ',
    leadAfter: '.',
    bio: 'Engineering microbes that turn methane into useful molecules, increasingly with the help of agentic coding tools.',
    scroll: 'scroll'
  },
  ko: {
    eyebrow: 'KRIBB · C1팀 · 박사후연구원',
    name: '이규민',
    leadBefore: '',
    leadAfter: '',
    bio: '메탄을 유용한 물질로 전환하는 미생물을 만든다. 에이전틱 코딩 도구를 적극 활용한다.',
    scroll: '아래로'
  }
} as const;

const t = copy[lang];
---
<section
  id="hero"
  class="relative w-full min-h-[88vh] bg-background pb-16 md:pb-24"
>
  <div class="mx-auto max-w-grid w-full px-6 md:px-12 pt-24 md:pt-32 pb-12 md:pb-16">
    <p class="text-sm font-mono uppercase tracking-wider text-muted-foreground mb-6">
      {t.eyebrow}
    </p>

    <h1 class="font-sans font-bold tracking-tight text-foreground text-5xl md:text-6xl lg:text-7xl mb-6">
      {t.name}
    </h1>

    <p class="text-2xl md:text-3xl text-foreground mb-6 max-w-3xl">
      {t.leadBefore}
      <span
        id="typewriter-slot"
        class="inline-block min-w-[34ch] align-baseline whitespace-nowrap"
        data-lang={lang}
      ><Typewriter client:load lang={lang} /></span>{t.leadAfter}
    </p>

    <p class="text-base md:text-lg text-muted-foreground max-w-2xl mb-10 leading-relaxed">
      {t.bio}
    </p>

    <p aria-hidden="true" class="mt-12 text-xs font-mono uppercase tracking-wider text-muted-foreground">
      ↓ {t.scroll}
    </p>
  </div>
</section>
