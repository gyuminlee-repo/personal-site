---
import ScholarMetrics from '../ScholarMetrics.astro';
import ScholarChart from '../ScholarChart.astro';
import PublicationList from '../PublicationList.astro';
import metrics from '../../data/scholar_metrics.json';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;

const eyebrow = lang === 'ko' ? '논문' : 'PUBLICATIONS';
const heading = lang === 'ko' ? '논문' : 'Publications';
const subtitle = lang === 'ko'
  ? 'Google Scholar에서 매일 자동 갱신.'
  : 'Synced daily from Google Scholar.';
const profileLink = lang === 'ko'
  ? 'Google Scholar 프로필 전체 보기 →'
  : 'View full profile on Google Scholar →';

const scholarUrl = metrics.scholar_url
  || 'https://scholar.google.com/citations?user=cnTN6OkAAAAJ';
---
<section id="publications" class="py-24 md:py-32 border-t border-border">
  <div class="mx-auto max-w-grid px-6 md:px-8">
    <header class="mb-12 md:mb-16 max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-muted-foreground mb-3">{eyebrow}</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-foreground mb-4">{heading}</h2>
      <p class="text-base text-muted-foreground">{subtitle}</p>
    </header>

    <div class="grid gap-8 md:grid-cols-12 md:gap-10 mb-12 md:mb-16">
      <div class="md:col-span-7">
        <ScholarMetrics lang={lang} />
      </div>
      <div class="md:col-span-5 md:flex md:items-end md:justify-end">
        <ScholarChart lang={lang} />
      </div>
    </div>

    <PublicationList lang={lang} />

    <div class="mt-12 md:mt-16 text-sm">
      <a
        href={scholarUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary hover:underline underline-offset-4"
      >
        {profileLink}
      </a>
    </div>
  </div>
</section>
