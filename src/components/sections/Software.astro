---
import SoftwareCard from '../SoftwareCard.astro';
import projectsData from '../../content/projects.json';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;

const eyebrow = lang === 'ko' ? '소프트웨어' : 'SOFTWARE';
const heading = lang === 'ko' ? '지금 만들고 있는 것들' : "Things I'm building";
const intro = lang === 'ko'
  ? '합성생물학 실험과 운영을 잇는 도구들. 일부는 공개, 일부는 lab 내부 사용.'
  : 'Tools that connect synthetic biology experiments with day-to-day operations. Some open, some lab-internal.';

const yearRank = (year: string) => {
  const match = year.match(/(\d{4})/);
  return match ? parseInt(match[1], 10) : 0;
};

const projects = [...projectsData.projects].sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return yearRank(b.year) - yearRank(a.year);
});
---

<section id="software" class="py-24 md:py-32 border-t border-border">
  <div class="mx-auto max-w-grid px-6 md:px-8">
    <header class="mb-12 md:mb-16 max-w-2xl">
      <p class="text-xs uppercase tracking-widest text-muted-foreground mb-3">{eyebrow}</p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-foreground mb-4">{heading}</h2>
      <p class="text-base text-muted-foreground">{intro}</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <SoftwareCard project={project} lang={lang} />
      ))}
    </div>
  </div>
</section>
