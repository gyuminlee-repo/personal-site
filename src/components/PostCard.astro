---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'posts'>;
  lang: 'en' | 'ko';
}
const { post, lang } = Astro.props;

const href = (lang === 'ko' ? '/ko/posts/' : '/posts/') + post.slug;
const dateStr = post.data.date.toISOString().split('T')[0];

// Excerpt: frontmatter description-like fallback to body first 80 chars
const rawExcerpt = (() => {
  const body = (post.body ?? '').trim();
  if (!body) return '';
  const firstPara = body.split(/\n\s*\n/)[0].replace(/[#>*_`\[\]]/g, '').trim();
  return firstPara.length > 120 ? firstPara.slice(0, 117) + '…' : firstPara;
})();
---
<article class="group rounded-lg border border-border bg-card p-6 transition hover:border-foreground/40">
  <a href={href} class="block">
    {post.data.cover_image && (
      <img
        src={post.data.cover_image}
        alt=""
        loading="lazy"
        class="mb-4 aspect-[16/9] w-full rounded-md object-cover"
      />
    )}
    <div class="flex items-center gap-3 text-xs">
      <time class="font-mono tabular-nums text-muted-foreground" datetime={dateStr}>{dateStr}</time>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {post.data.tags.slice(0, 3).map((tag) => (
            <span class="inline-flex items-center rounded border border-border bg-secondary px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-muted-foreground">{tag}</span>
          ))}
        </div>
      )}
    </div>
    <h2 class="mt-3 text-xl font-semibold tracking-tight text-foreground transition group-hover:text-primary">
      {post.data.title}
    </h2>
    {rawExcerpt && (
      <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{rawExcerpt}</p>
    )}
  </a>
</article>
